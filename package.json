{
  "name": "sui-paylink",
  "private": true,
  "version": "0.1.0",
  "description": "Gasless stablecoin escrow payment links for cross-border digital service work on Sui.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w @suipaylink/api\" \"npm run dev -w @suipaylink/web\"",
    "dev:api": "npm run dev -w @suipaylink/api",
    "dev:web": "npm run dev -w @suipaylink/web",
    "build": "npm run build -ws --if-present",
    "build:static-demo": "VITE_STATIC_DEMO=true VITE_BASE_PATH=/sui-paylink/ npm run build -w @suipaylink/web && cp apps/web/dist/index.html apps/web/dist/404.html",
    "build:cloudflare-demo": "VITE_STATIC_DEMO=true VITE_BASE_PATH=/ npm run build -w @suipaylink/web && cp apps/web/dist/index.html apps/web/dist/404.html",
    "start": "npm run start -w @suipaylink/api",
    "preview:prod": "npm run build && npm start",
    "typecheck": "npm run typecheck -ws --if-present",
    "smoke:api": "node scripts/api-regression-smoke.mjs",
    "smoke:preview": "node scripts/production-preview-smoke.mjs",
    "smoke:static-demo": "npm run build:static-demo && node scripts/static-demo-smoke.mjs",
    "smoke:cloudflare-demo": "npm run build:cloudflare-demo && STATIC_DEMO_BASE_PATH=/ node scripts/static-demo-smoke.mjs",
    "submission:readiness": "node scripts/submission-readiness.mjs",
    "registration:audit": "node scripts/registration-audit.mjs",
    "public:preflight": "node scripts/public-preflight.mjs",
    "evidence:browser-wallet": "node scripts/export-browser-wallet-e2e.mjs",
    "sponsor:bootstrap": "node scripts/sponsor-bootstrap.mjs",
    "sponsor:readiness": "node scripts/sponsor-readiness.mjs",
    "chain:build": "sui move build --path contracts --build-env testnet",
    "chain:test": "sui move test --path contracts --build-env testnet",
    "chain:deploy:testnet": "bash scripts/testnet-deploy.sh",
    "chain:smoke:testnet": "bash scripts/testnet-smoke.sh",
    "chain:smoke:refund:testnet": "bash scripts/testnet-refund-smoke.sh",
    "chain:smoke:two-party:testnet": "bash scripts/testnet-two-party-smoke.sh",
    "chain:smoke:mock-usdc:testnet": "bash scripts/testnet-mock-usdc-smoke.sh",
    "chain:smoke:sponsored-mock-usdc:testnet": "node scripts/testnet-sponsored-mock-usdc-smoke.mjs",
    "lint": "npm run lint -ws --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
